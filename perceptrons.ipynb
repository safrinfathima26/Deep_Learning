   "metadata": {},
   "outputs": [],
   "source": [
    "def perceptron(X1,x2,w1,w2,b):\n",
    "    g=X1*w1+X2*w2+b\n",
    "    if g>=0:\n",
    "        return 1\n",
    "    else:\n",
    "        return 0\n",
    "    z=1/(1+np.exp(-g))\n",
    "    if z>=0:\n",
    "        return 1\n",
    "    else:\n",
    "        return 0"
   ]
  }
